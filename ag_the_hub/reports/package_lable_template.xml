<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_print_label_single_sku_per_box_document">
        <t t-call="web.basic_layout">
            <div class="page">
                <t t-foreach="doc.wro_single_sku_per_box_line_ids" t-as="line">
                    <t t-set="wro_id" t-value="doc.wro_id"/>
                    <div class="row w-100 d-flex">
                        <div class="w-75 text-center">
                            <h2 style="color:red;">
                                <span>WRO # <t t-esc="wro_id.name"/></span>
                            </h2>
                        </div>
                        <div class="w-25 d-flex justify-content-end">
                            <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 45px;" alt="Logo"/>
                        </div>
                    </div>
                    <div class="row text-center">
                        <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=1' % ('Code128', line.package_number, 800, 170)" style="border-top:1px solid #ccc;"/>
                    </div>
                    <p style="page-break-after:always;"/>
                   
                    <t t-if="line.send_as == 'non_consolidated'" t-foreach="int(doc.qty_per_box)" t-as="qty">

                        
                    <div class="row text-center">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 45px;" alt="Logo"/>
                        <img t-att-src="'/report/barcode/?type=%s&amp;value=%s&amp;width=%s&amp;height=%s&amp;humanreadable=1' % ('Code128', line.package_number+'/'+str(qty+1), 800, 170)" style="border-top:1px solid #ccc;"/>
                        
                    </div>
                        <p style="page-break-after:always;"/>
                    </t>
                </t>
            </div>
        </t>
    </template>



