<odoo>
	<data noupdate="1">

		<record id="ir_cron_generate_bill" model="ir.cron">
        <field name="name">Generate Invoice For Merchant</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="code">model.generate_invoice_for_merchant()</field>
        <field name="state">code</field>
    </record>
</data>
<data>
    <record id="ir_cron_update_dashboard" model="ir.cron">
        <field name="name">Update Dashboard</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="model_id" ref="ag_the_hub.model_dashboard_dynamics"/>
        <field name="code">model.update_merchant_dashboard()</field>
        <field name="state">code</field>
    </record>
</data>
</odoo>
