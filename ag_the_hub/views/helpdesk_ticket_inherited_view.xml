<?xml version="1.0" encoding="utf-8"?>
<odoo>




<record id="helpdesk_ticket_view_form_inherit_custom" model="ir.ui.view">
        <field name='name'>helpdesk.ticket.form.inherit.repair.stock.user</field>
        <field name="model">helpdesk.ticket</field>
        <field name="priority">50</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="category_id"/>
            </field>
            <field name="partner_id" position="replace">
                <field name="partner_id" string="Contact Name" class="field_partner_id" domain="['|', ('company_id', '=', False), ('company_id', '=', company_id)]" widget="res_partner_many2one" context="{'default_name': partner_name, 'default_email': partner_email, 'default_phone': partner_phone}"/>

            <!-- <field name="wallet_balance"/> -->

                
                            
                
        </field>
            <field name="email_cc" position="after">
                <field name="wo_id" invisible="1"/>
                <field name="delivery_status" attrs="{'invisible': [('wo_id', '=', False)]}"/>
            </field>
            <field name="description" position="replace">
            	<notebook>
            		<page string="Ticket Description">
            			<field name="description"/>
            		</page>

            		<page string="Resolution Feedback">
            			<field name="resolution_feedback"/>
            		</page>
            	</notebook>
        </field>
    </field>
        
    </record>


    <record id="helpdesk_ticket_type_view_tree_inherit_custom" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.tree.inherit.custom</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_type_view_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="parent_id" widget="many2many_tags"/>
            </field>
        </field>
    </record>
</odoo>
