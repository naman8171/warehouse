<odoo>
    <data>
        <!-- explicit list view definition -->

        <record model="ir.ui.view" id="box_size_list_view">
            <field name="name">box.size.list.view</field>
            <field name="model">box.size</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="product_id"/>
                    <field name="price"/>
                    <field name="type"/>
                    
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="box_size_form_view">
            <field name="name">box.size.form.view</field>
            <field name="model">box.size</field>
            <field name="arch" type="xml">
            <form>
                
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" class="oe_inline" />
                            </h1>
                        </div>
                    <group>
                        <group>
                            <field name="product_id" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="price" required="1"/>
                            <field name="type"/>
                            <field name="sequence"/>
                            
                        </group>
                    </group>
                        
                </sheet>
                
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="box_size_action_window">
        <field name="name">Box Size</field>
        <field name="res_model">box.size</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Box Type
            </p>
        </field>
    </record>
    
    <!-- Top menu item -->
    <menuitem id="menu_box_type" name="Box Type" action="box_size_action_window"
    parent="ag_the_hub.menu_thehub_config" sequence="3"/>



  </data>
</odoo>