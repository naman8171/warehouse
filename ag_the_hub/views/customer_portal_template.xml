<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_add_customer" name="Add Customer">
        <!-- Add Product Manually Modal -->

        <!-- The Modal -->
    <div class="modal fade" id="addCustomer">
        <div class="modal-dialog modal-lg">
        <div class="modal-content">
    
            <!-- Modal Header -->
            <div class="modal-header">
            <h4 class="modal-title"> Add New Customers</h4>
            <button type="button" class="close" data-dismiss="modal">&amp;times;</button>
            </div>
    
            <!-- Modal body -->
            <div class="modal-body">
                <form id="add_new_customer" action="/add/new/customer" method="post"
                              enctype="form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        
                <div class="row">
                  
                    <div class="col-md-6">
                        
                            <div class="form-group">
                              <label for="name">Customer Name</label>
                              <input type="text" class="form-control" id="customer_name" name="customer_name" placeholder="Enter Customer Name" required="1"/>
                            </div>
                            <div class="form-group">
                              <label for="email">Customer Email</label>
                              <input type="email" class="form-control" id="email" name="email" placeholder="Enter Customer Email" required="1"/>
                            </div>
                            <div class="form-group">
                                <label for="address">Street Adress 1</label>
                               <input type="text" class="form-control" id="street" name="street" placeholder="Enter street address" required="1"/>
                            </div>
                            <div class="form-group">
                                <label for="unit">Unit</label>
                                <input type="text" class="form-control" id="unit" name="unit"/>
                            </div>
                            <div class="form-group">
                                <label for="zip">Zip</label>
                                <input type="text" class="form-control" id="zip" name="Zip" required="1"/>
                            </div>
                            

                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="zip">Select Country</label>
                           <select id="country_id" class="form-control" required="required" name="country_id">
                                        <option value="" selected="selected" disabled="True">Please select country...</option>
                                        <t t-foreach="country_ids" t-as="country">
                                            <option  t-att-value="country.id" t-att-selected="'selected' if country_id and country_id.id == country.id else None">
                                                <t t-esc="country.name"/>
                                            </option>
                                        </t>
                                    </select>
                        </div>
                            <div class="form-group">
                              <label for="uname">Phone Number:</label>
                              <input type="tel" class="form-control" id="phone" name="phone" placeholder="Enter Number"/>
                            </div>
                            <div class="form-group">
                                <label for="address">Street Adress 2</label>
                                <input type="text" class="form-control" id="street2" name="street2" placeholder="Enter street address"/>
                            </div>
                            <div class="form-group">
                                <label for="zip">select state</label>
                                <select id="state_id" class="form-control" required="required" name="state_id">
                                        <option value="" selected="selected" disabled="True">Please select State...</option>
                                        <t t-foreach="state_ids" t-as="state">
                                            <option  t-att-value="state.id" t-att-selected="'selected' if state_id and state_id.id == state.id else None">
                                                <t t-esc="state.name"/>
                                            </option>
                                        </t>
                                    </select>
                            </div>
                            
                    </div>
              
                </div>
                <div class="modal-footer">
                 <button type="submit" class="btn btn-success float-right" style="font-size:20px;font-weight:bold;">Add Customer</button>
                          
                <button type="button" class="btn btn-danger" data-dismiss="modal">Close</button>
            </div>
                </form>

            </div>
    
            <!-- Modal footer -->
            
    
        </div>
        </div>
    </div>



        
        
    </template>

    <template id="portal_layout" name="Portal layout: customer menu entry" inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'customer' or customer" class="col-lg-2" t-attf-class="breadcrumb-item">
                <a t-if="customer" t-attf-href="/my/customer?{{ keep_query() }}">Customers</a>
                <t t-else="">Customers</t>
            </li>
        </xpath>
    </template>

