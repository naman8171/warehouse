<odoo>
    <data>
        <!-- explicit list view definition -->

        <record model="ir.ui.view" id="dashboard_dynamics_list_view">
            <field name="name">dashboard.dynamics.list.view</field>
            <field name="model">dashboard.dynamics</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="merchand_id" class="oe_inline" />
                    <field name="total_products" />
                            <field name="stock_one_hand" />
                            <field name="low_stock_product"/>
                            <field name="out_stock_product"/>
                            <field name="top_stock_product"/>
                            <field name="inventory_value"/>
                             <field name="reorder_alert"/>
                            <field name="most_recent_wo"/>
                            <field name="most_recent_wro"/>
                            <field name="recent_wo_status"/>
                    
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="dashboard_dynamics_form_view">
            <field name="name">dashboard.dynamics.form.view</field>
            <field name="model">dashboard.dynamics</field>
            <field name="arch" type="xml">
            <form>
                
                <sheet>
                    <div class="oe_title">
                        <label for="merchand_id" class="oe_edit_only"/>
                            <h1>
                                <field name="merchand_id" class="oe_inline" />
                            </h1>
                        </div>
                    <group>
                        <group>
                            <field name="total_products" />
                            <field name="stock_one_hand" />
                            <field name="low_stock_product"/>
                            <field name="out_stock_product"/>
                            <field name="top_stock_product"/>
                            <field name="inventory_value"/>
                            
                        </group>
                        <group>
                            <field name="reorder_alert"/>
                            <field name="most_recent_wo"/>
                            <field name="most_recent_wro"/>
                            <field name="recent_wo_status"/>
                        </group>
                    </group>
                        
                </sheet>
                
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="merchant_dashboard_action_window">
        <field name="name">Merchant Dashboard</field>
        <field name="res_model">dashboard.dynamics</field>
        <field name="view_mode">tree,form</field>
        
    </record>
    
    <!-- Top menu item -->
    <menuitem id="menu_merchant_dashboard" name="Merchant Dashboard Record" action="merchant_dashboard_action_window"
    parent="ag_the_hub.menu_thehub_config" sequence="8"/>



  </data>
</odoo>
