<odoo>
    <data>
        <!-- explicit list view definition -->

        <record model="ir.ui.view" id="thehub_packing_type_list_view">
            <field name="name">thehub.packing.type.list.view</field>
            <field name="model">thehub.packing.type</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="packing_categ"/>
                    <field name="packing_type"/>
                    <field name="price"/>
                    
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="thehub_packing_type_form_view">
            <field name="name">thehub.packing.type.form.view</field>
            <field name="model">thehub.packing.type</field>
            <field name="arch" type="xml">
            <form>
                
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" class="oe_inline" />
                            </h1>
                            <field name="display_name" invisible="1"/>
                        </div>
                    <group>
                        <group>
                            <field name="packing_categ" required="1" />
                            <field name="packing_type"/>
                            <field name="product_id" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="price"/>
                            
                        </group>
                    </group>
                        
                </sheet>
                
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="thehub_packing_type_action_window">
        <field name="name">Packing Type</field>
        <field name="res_model">thehub.packing.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Packing typr
            </p>
        </field>
    </record>
    
    <!-- Top menu item -->
    <menuitem id="menu_packing_type" name="Packing Type" action="thehub_packing_type_action_window"
    parent="ag_the_hub.menu_thehub_config" sequence="2"/>



    <record id="view_location_form_inherit_custom" model="ir.ui.view">
            <field name="name">stock.location.form.inherit</field>
            <field name="model">stock.location</field>
            <field name="inherit_id" ref="stock.view_location_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='usage']" position="before">
                    <field name="storage_type_id"/>
                    <field name="storage_type"/>
                    <field name="location_full" attrs="{'invisible': [('storage_type', '!=', 'Dedicated')]}"/>
                    <field name="billing_start" attrs="{'invisible': [('storage_type', '!=', 'Dedicated')]}"/>
                    <field name="billing_date" attrs="{'invisible': [('storage_type', '!=', 'Dedicated')]}"/>
                    <field name="location_scan_name"/>
                </xpath>
            </field>
        </record>

  </data>
</odoo>
