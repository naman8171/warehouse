                                                <div t-if="searchbar_groupby"
                                                    class="form-inline ml-lg-2">
                                                    <span class="small mr-1 navbar-text">Group By:</span>
                                                    <div class="btn-group">
                                                        <button id="portal_searchbar_groupby"
                                                            data-toggle="dropdown"
                                                            class="btn btn-secondary btn-sm dropdown-toggle">
                                                            <t
                                                                t-esc="searchbar_groupby[groupby].get('label', 'None')" />
                                                        </button>
                                                        <div class="dropdown-menu"
                                                            aria-labelledby="portal_searchbar_groupby">
                                                            <t t-foreach="searchbar_groupby"
                                                                t-as="option">
                                                                <a
                                                                    t-att-href="default_url + '?' + keep_query('*', groupby=option)"
                                                                    t-attf-class="dropdown-item#{groupby == option and ' active' or ''}">
                                                                    <span
                                                                        t-esc="searchbar_groupby[option].get('label')" />
                                                                </a>
                                                            </t>
                                                        </div>
                                                    </div>
                                                </div>
                                                <a type="button" class="btn btn-primary"
                                                    href="/send/inventory/portal">
                                                    <i class="fa fa-plus"></i> Add New WRO</a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="">
                                        <table class="table table-hove wro_table">
                                            <t t-foreach="grouped_wros" t-as="wro_ids">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th colspan="6">
                                                            <em t-if="groupby=='Warehouse'"
                                                                class="font-weight-normal text-muted">WRO
                                                                in Warhouse:</em>
                                                            <em t-if="groupby=='Merchant'"
                                                                class="font-weight-normal text-muted">WRO
                                                                in Merchant:</em>
                                                            <em t-if="groupby=='Picking Method'"
                                                                class="font-weight-normal text-muted">WRO
                                                                in Pickup Method:</em>
                                                            <em t-if="groupby=='Shipping Type'"
                                                                class="font-weight-normal text-muted">WRO
                                                                in Shipping Type:</em>
                                                            <em t-if="groupby=='Status'"
                                                                class="font-weight-normal text-muted">WRO
                                                                in Status:</em>
                                                            <span t-if="groupby=='Warehouse'"
                                                                t-field="wro_ids[0].warehouse_id.name" />
                                                            <span t-if="groupby=='Merchant'"
                                                                t-field="wro_ids[0].merchand_id.name" />
                                                            <span t-if="groupby=='Picking Method'"
                                                                t-field="wro_ids[0].pickup_method" />
                                                            <span t-if="groupby=='Shipping Type'"
                                                                t-field="wro_ids[0].shipping_type" />

                                                            <span t-if="groupby=='Status'"
                                                                t-field="wro_ids[0].status" />

                                                        </th>
                                                    </tr>
                                                    <tr>
                                                        <th>


                                                            <input type="checkbox" id="select_all"
                                                                name="select_all" value="1" />
                                                        </th>
                                                        <th scope="col"
                                                            t-attf-class="{{'thead-light' if not groupby == 'none' else ''}}"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">
                                                            Name</th>
                                                        <th scope="col"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">
                                                            Merchant</th>
                                                        <th scope="col"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">Third
                                                            Party Ref #</th>
                                                        <th scope="col"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">
                                                            Warehouse</th>
                                                        <th scope="col"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">Shipping
                                                            Type</th>
                                                        <th scope="col"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">Picking
                                                            Method</th>
                                                        <!-- <th scope="col"  class="px-6 py-3
                                                        text-left text-uppercase" style="font-size:
                                                        12px; color:#666d7d" >Custom Packaging</th> -->
                                                        <!-- <th scope="col"  class="px-6 py-3
                                                        text-left text-uppercase" style="font-size:
                                                        12px; color:#666d7d" >Size</th> -->
                                                        <th scope="col"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">Arrival
                                                            Date</th>
                                                        <th scope="col"
                                                            class="px-6 py-3 text-left text-uppercase"
                                                            style="font-size: 12px; color:#666d7d">
                                                            Status </th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="wro_ids" t-as="wro_id">
                                                        <td class="px-6 py-4 ">
                                                            <input type="checkbox"
                                                                id="wro_status_line"
                                                                name="wro_status_line"
                                                                t-att-value="wro_id.id" />
                                                        </td>

                                                        <td class="px-6 py-4 ">
                                                            <a
                                                                t-att-href="'/my/wros/%s' %(wro_id.id)">
                                                                <t t-esc="wro_id.name" />
                                                            </a>
                                                        </td>
                                                        <td class="px-6 py-4 ">
                                                            <span t-field="wro_id.merchand_id" />
                                                        </td>
                                                        <td class="px-6 py-4 ">
                                                            <span t-field="wro_id.third_party_ref" />
                                                        </td>
                                                        <td class="px-6 py-4 ">
                                                            <t t-esc="wro_id.warehouse_id.name" />
                                                        </td>
                                                        <td class="px-6 py-4 ">
                                                            <span t-field="wro_id.shipping_type" />
                                                        </td>
                                                        <td class="px-6 py-4">
                                                            <span t-field="wro_id.pickup_method" />
                                                        </td>
                                                        <!-- <td class="px-6 py-4 "> <t
                                                        t-esc="wro_id.arrival_date"/> </td> -->
                                                        <!-- <td class="px-6 py-4 ">22.2 </td> -->
                                                        <td class="px-6 py-4 ">
                                                            <t t-esc="wro_id.arrival_date" />
                                                        </td>
                                                        <td t-if="wro_id.status">
                                                            <button
                                                                t-if="wro_id.status=='request_submitted'"
                                                                type="submit"
                                                                class="btn btn-primary">
                                                                <span t-field="wro_id.status" />
                                                            </button>
                                                            <button t-elif="wro_id.status=='stored'"
                                                                type="submit"
                                                                class="btn btn-success">
                                                                <span t-field="wro_id.status" />
                                                            </button>
                                                            <button t-else="" type="submit"
                                                                class="btn btn-primary"
                                                                style="background:grey;">
                                                                <span t-field="wro_id.status" />
                                                            </button>

                                                        </td>
                                                    </tr>

                                                </tbody>
                                            </t>
                                        </table>

                                    </div>
                                </div>
                            </div>
                            <br />
