<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_layout" name="Portal layout: product menu entry"
        inherit_id="portal.portal_breadcrumbs" priority="40">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'product' or product" class="col-lg-2"
                t-attf-class="breadcrumb-item">
                <a t-if="product" t-attf-href="/my/product?{{ keep_query() }}">Products</a>
                <t t-else="">Products</t>
            </li>
            <li t-if="page_name == 'wro' or wro" class="col-lg-2" t-attf-class="breadcrumb-item">
                <a t-if="wro" t-attf-href="/my/wros?{{ keep_query() }}">Warehouse Receiving Orders</a>
                <t t-else="">Warehouse Receiving Orders</t>
            </li>
        </xpath>
    </template>

    <template id="portal_my_wros" name="My WROs">
        <t t-call="portal.frontend_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />

            <nav aria-label="breadcrumb flex justify-between"
                style="background-color:#e9ecef;margin-left: 0%;">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item ">
                        <a class="bold text-danger" href="/my">THL</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page"
                        style="background: transparent;">Warehouse Receiving Order</li>
                </ol>
            </nav>
            <section class="wro_status">
                <div class="container-fuild p-3">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="card">
                                <div class="card-header">
                                    <div class="flex justify-between items-center">
                                        <h4 class="card-title"> Warehouse Receiving Order (<t
                                                t-esc="wro_count" />)</h4>
                                    </div>
                                </div>
                                <div class="p-6">


                                    <div class="card-header pl-1 pr-1 bg-light">
                                        <div class="flex justify-between items-center">
                                            <div class="d-flex justify-content-end mr-3">
