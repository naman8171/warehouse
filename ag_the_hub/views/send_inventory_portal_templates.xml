				                	function onchange_shipping_type() {
				                		var parcel_radio = document.getElementById('parcel');
				                		var pallet_radio = document.getElementById('pallet');
				                		var container_radio = document.getElementById('container');

				                		var parcel = document.getElementById("inventory_type_parcel");
				                		var pallet = document.getElementById("inventory_type_pallet");

				                		var inventory_type_parcel1 = document.getElementById("inventory_type_parcel1");
				                		var inventory_type_parcel2 = document.getElementById("inventory_type_parcel2");

				                		var inventory_type_pallet1 = document.getElementById("inventory_type_pallet1");
				                		var inventory_type_pallet2 = document.getElementById("inventory_type_pallet2");

				                		var shipping_type_btn = document.getElementById("shipping_type_submit");

									  	if(parcel_radio.checked){
									  		parcel.classList.remove("d-none");
									  		pallet.classList.add("d-none");
									  	}else if(pallet_radio.checked){
									  		pallet.classList.remove("d-none");
									  		parcel.classList.add("d-none");
									  	}else if(container_radio.checked){
									  		parcel.classList.add("d-none");
									  		pallet.classList.add("d-none");
									  	}
									  	if(parcel_radio.checked &amp;&amp; (inventory_type_parcel1.checked || inventory_type_parcel2.checked)){
									  		shipping_type_btn.classList.remove("disabled");
									  	}
									  	else if(pallet_radio.checked &amp;&amp; (inventory_type_pallet1.checked || inventory_type_pallet2.checked)){
									  		shipping_type_btn.classList.remove("disabled");
									  	}
									  	else if(container_radio.checked){
									  		shipping_type_btn.classList.remove("disabled");
									  	} 
									  	else{
									  		shipping_type_btn.classList.add("disabled");
									  	}      
									}
