<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<template id="portal_send_inventory_form" name="Send Inventory">
        <t t-call="portal.frontend_layout">
        	<t t-set="is_portal" t-value="True"/>
            <div id="wrap" class='o_portal_wrap'>
                <div class="container-fluid mb64 o_products_search_index">
	                <div class="oe_structure" id="oe_structure_portal_my_home_1"/>
	                <h1>Welcome, <span t-field="user_id.partner_id"/></h1>
	                <p>Complete the steps below to start shipping with The Hub.</p>
	                <t t-if="user_id.partner_id and user_id.partner_id.thehub_account_activated">
	                	<!-- <form class="w-75" id="send_inventory_form" action="/send/inventory" method="post" enctype="form-data"> -->
	                		<input type="hidden" id="wroId" name="wro_id" t-att-value="wro_id.id if wro_id else ''"/>
	                		<a t-att-href="'/send/inventory/portal/%s' %(wro_id.id)" t-if="wro_id">
	                			<t t-esc="wro_name"/></a>
		                	<div id="accordion">
		                		<style>
		                			a.btn-outline-info {
									    color: #17a2b8 !important;
									    border-color: #17a2b8;
									}
									a.btn-outline-info:hover {
									    color: #fff !important;
									}
		                		</style>
		  						<div class="card mb-5" style="box-shadow: 0 0 6px 0 #0003;">
		    						<div class="p-4" id="headingOne">
		    							<h4 class="mb-0 float-left">
							    			Which The Hub warehouse are you shipping to?
							    		</h4>
		        						<a id="warehouse_edit_btn" type="button" t-att-class="'btn btn-outline-info float-right %s' % ('disabled' if not wh_id else '')" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
		          							Edit
		        						</a>
		    						</div>

		    						<div id="collapseOne" t-att-class="'collapse %s'  % ('show' if not wh_id else '')" aria-labelledby="headingOne" data-parent="#accordion">
		      							<div class="card-body">
											<div class="form-group w-75 ml-4">
												<label for="warehouse_id" style="font-size: 20px;">Sending to:</label>
												<select id="warehouse" class="form-control" required="required" name="warehouse_id">
	                                                <option value="" selected="selected" disabled="True">Please select an option...</option>
	                                                <t t-foreach="warehouse_ids" t-as="warehouse_id">
		                                                <option  t-att-value="warehouse_id.id" t-att-selected="'selected' if wh_id and warehouse_id.id == wh_id.id else None">
		                                                    <t t-esc="warehouse_id.name"/>
		                                                </option>
		                                            </t>
	                                            </select>
	                                            <p class="mt-1" style="font-size:14px"><strong>Tip!</strong> Don’t know where to send your inventory? Choose the warehouse closest to you or your customers.</p>
											</div>
											<button type="button" t-att-class="'btn btn-primary float-left ml-4 mb-4 %s' % ('disabled' if not wh_id else '')" id="warehouse_submit">Save &amp; Continue</button>
		      							</div>
		    						</div>
		  						</div>
								<div class="card mb-5" style="box-shadow: 0 0 6px 0 #0003;">
		    						<div class="p-4" id="headingTwo">
		    							<h4 class="mb-0 float-left">
							    			Search for item(s) you’re sending to The Hub
							    		</h4>
								        <a id="search_product_edit_btn" type="button" t-att-class="'btn btn-outline-info float-right %s' % ('disabled' if not wro_line_ids else '')" data-toggle="collapse" data-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
								          	Edit
								        </a>
									</div>
		    						<div id="collapseTwo" t-att-class="'collapse %s'  % ('show' if wh_id and not wro_line_ids else '')" aria-labelledby="headingTwo" data-parent="#accordion">
		      							<div class="card-body">
		      								<div class="o_product_tags_form w-100">
			      								<style>
			      									.has-search .form-control {
													    padding-left: 2.375rem;
													}

													.has-search .form-control-feedback {
													    position: absolute;
													    z-index: 2;
													    display: block;
													    width: 2.375rem;
													    height: 2.375rem;
													    line-height: 2.375rem;
													    text-align: center;
													    pointer-events: none;
													    color: #aaa;
													}
			      								</style>
			      								<div class="d-flex flex-column flex-sm-row justify-content-between w-75">
								                    <select class="multi_select" id="select_multi_product" name="multi_products[]"  multiple="multiple" style="margin:8px auto;min-width: 176px;min-height: 40px;">
														<t t-foreach="product_ids" t-as="product_id" t-key='product_id.id'>
															<option t-att-value="product_id.id">
																<t t-esc='product_id.display_name'/>
															</option>
														</t>
													</select>
								                    <!-- <ul class="o_product_filters o_product_index_topbar_filters nav w-100">
								                    	<li class="nav-item dropdown mr-2 my-1 w-50 form-group has-search">
															    <span class="fa fa-search form-control-feedback"></span>
											    				<input id="o_product_search_box" type="text" class="form-control dropdown-toggle" data-toggle="dropdown" placeholder="Search by item name"/>

												            <div class="dropdown-menu">
												                <a class="dropdown-item o_dropdown_reset_tags"></a>
												                <t t-foreach="product_ids" t-as="product_id">
												                    <label t-attf-class="dropdown-item {{ 'active' if product_id.id in search_product_ids.ids else '' }}">
												                        <input type="checkbox" name="product_id" multiple="multiple"
												                            t-att-value="product_id.id"
												                            t-att-checked="'checked' if product_id.id in search_product_ids.ids else None"/>
												                        <t t-esc="product_id.name"/>
												                    </label>
												                </t>
												            </div>
												        </li>
								                    </ul> -->
									                <!-- <div class="ml-4 float-right">
														<a style="color: #007bff; text-decoration: none;" class="ml-2" data-toggle="modal" data-target="#importProducts" href="#">Import</a>
													</div> -->
								            	</div>
									            <div t-att-class="'%s' % ('d-none' if not wro_line_ids else '')" id="productTableDiv">
										            <table class="table mt-5" id="productTable">
													  	<thead>
														    <tr>
																<th scope="col">Item Name</th>
																<th scope="col">SKU</th>
																<th scope="col">Platform</th>
																<th scope="col">Quantity to Send per package</th>
																<th scope="col">Package value (₦)</th>
																<th scope="col">Action</th>
														    </tr>
													  	</thead>
													  	<tbody>
													  		<t t-foreach="wro_line_ids" t-as="wro_line_id">
													  			<tr t-att-id="'product_id_%s' % (wro_line_id.product_id.id)">
									                                <td><t t-esc="wro_line_id.product_id.name"/></td>
									                                <td><t t-esc="wro_line_id.product_sku"/></td>
									                                <td><t t-esc="wro_line_id.product_id.platform"/></td>
									                                <td><input type="number"  min="1" class="form-control" t-att-id="'product_qty_%s' % (wro_line_id.product_id.id)" t-att-name="'product_qty_%s' % (wro_line_id.product_id.id)" t-att-value="wro_line_id.product_qty" onchange="setTwoNumberDecimal(this)"/></td>
									                                <td><input type="number" step="0.01" min="1" class="form-control" t-att-id="'package_value_%s' % (wro_line_id.product_id.id)" t-att-name="'package_value_%s' % (wro_line_id.product_id.id)" t-att-value="wro_line_id.package_value" onchange="setTwoNumberDecimal(this)"/></td>
									                                <td width="50px">
									                                    <button t-att-id="'delete_record_%s' % (wro_line_id.product_id.id)" type="button" class="btn btn-link line_record_delete" style="font-size:18px;color:black;" name="delete"><i class="fa fa-trash-o"/></button>
									                                </td>
									                        	</tr>
															</t>
													    </tbody>
													</table>
													<div class="form-check mt-3">
		  												<input class="form-check-input" type="checkbox" value="" id="productFragileCheckbox" name="all_product_dangerous" required="true" t-att-checked="true if wro_line_ids else false" style="margin-top: 1%;"/>
		  												<label class="form-check-label" for="all_product_dangerous">
		    												I confirm that I have marked all applicable items as fragile. <a type="button" data-toggle="modal" data-target="#herewhyimportant" class="btn btn-link" style="font-size:20px;font-weight:bold;color: #35979c;">Here's why its important.</a>
		  												</label>
		  												 <div class="modal fade" id="herewhyimportant" tabindex="-1" role="dialog" aria-labelledby="herewhyimportant" aria-hidden="true">
												            <div class="modal-dialog modal-dialog-centered" role="document" style="max-width:75% !important;">
												                <div class="modal-content">
												                    <div class="modal-body">


												                    	<div class="text-center d-block mt-2">
												                            <a class="font-size:14px" href="#" data-dismiss="modal" aria-label="Close">
												                                Close
												                            </a>
												                        </div>
												       				</div>
												       			</div>
												       		</div>
												       	</div>
													</div>
													<button type="button" t-att-class="'btn btn-primary float-left mt-3 mb-4 %s' % ('disabled' if not wro_line_ids else '')" id="products_submit">Save &amp; Continue</button>
												</div>
											</div>											
								      	</div>
								    </div>
								</div>
							  	<div class="card mb-5" style="box-shadow: 0 0 6px 0 #0003;">
							    	<div class="p-4" id="headingThree">
							      		<h4 class="mb-0 float-left">
							    			How will your inventory arrive to The Hub's fulfillment center?
							    		</h4>
						        		<a id="shipping_type_edit_btn" type="button" t-att-class="'btn btn-outline-info float-right %s' % ('disabled' if not shipping_type else '')" data-toggle="collapse" data-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
						          			Edit
						        		</a>
							    	</div>
							    	<div id="collapseThree" t-att-class="'collapse %s'  % ('show' if wro_line_ids and not shipping_type else '')" aria-labelledby="headingThree" data-parent="#accordion">
							      		<div class="card-body">
							        		<div class="form-group w-50 ml-4" style="font-size:20px;">
							        			<label for="shipping_type">Shipping Type:</label>
												<div class="form-check">
													<input class="form-check-input" type="radio" name="shipping_type" id="parcel" value="Parcel" onchange="onchange_shipping_type();" t-att-checked="true if shipping_type == 'parcel' else false"/>
													<label class="form-check-label" for="parcel">
														Parcel (standard shipping)
													</label>
												</div>
												<div class="form-check">
													<input class="form-check-input" type="radio" name="shipping_type" id="pallet" value="Palletized container" onchange="onchange_shipping_type();" t-att-checked="true if shipping_type == 'pallet' else false"/>
													<label class="form-check-label" for="pallet">
														Palletized container or LTL (less-than-truckload)
													</label>
												</div>
												<div class="form-check">
													<input class="form-check-input" type="radio" name="shipping_type" id="container" value="Floor loaded container" onchange="onchange_shipping_type();" t-att-checked="true if shipping_type == 'container' else false"/>
													<label class="form-check-label" for="container">
														Floor loaded container
													</label>
												</div>
											</div>
											<div t-att-class="'form-group w-50 ml-4 mt-2 %s' %('' if inventory_type_parcel else 'd-none')" style="font-size:20px;" id="inventory_type_parcel">
							        			<label for="inventory_type_parcel">How is your inventory configured?</label>
												<div class="form-check">
													<input class="form-check-input" type="radio" name="inventory_type_parcel" id="inventory_type_parcel1" onchange="onchange_shipping_type();" t-att-checked="true if inventory_type_parcel == 'single' else false"/>
													<label class="form-check-label" for="inventory_type_parcel1">
														One SKU per box
													</label>
													<div class="text-muted">Each box contains a single SKU</div>
												</div>
												<div class="form-check d-none">
													<input class="form-check-input" type="radio" name="inventory_type_parcel" id="inventory_type_parcel2" onchange="onchange_shipping_type();" t-att-checked="true if inventory_type_parcel == 'multiple' else false"/>
													<label class="form-check-label" for="inventory_type_parcel2">
														Multiple SKUs per box
													</label>
													<div class="text-muted">Each box has 2 or more SKUs</div>
												</div>
											</div>
											<div class="form-group w-50 ml-4 mt-2 d-none" style="font-size:20px;" id="inventory_type_pallet">
							        			<label for="inventory_type_pallet">How is your inventory configured?</label>
												<div class="form-check">
													<input class="form-check-input" type="radio" name="inventory_type_pallet" id="inventory_type_pallet1" onchange="onchange_shipping_type();" t-att-checked="true if inventory_type_pallet == 'single' else false"/>
													<label class="form-check-label" for="inventory_type_pallet1">
														One SKU per pallet
													</label>
													<div class="text-muted">Each pallet contains a single SKU</div>
												</div>
												<div class="form-check d-none">
													<input class="form-check-input" type="radio" name="inventory_type_pallet" id="inventory_type_pallet2" onchange="onchange_shipping_type();"/>
													<label class="form-check-label" for="inventory_type_pallet2">
														Multiple SKUs per pallet
													</label>
													<div class="text-muted">Each pallet has 2 or more SKUs</div>
												</div>
											</div>
											<button type="button" t-att-class="'btn btn-primary float-left ml-4 mb-4 %s' % ('disabled' if not shipping_type else '')" id="shipping_type_submit">Save &amp; Continue</button>
							      		</div>
							    	</div>
							  	</div>
							  	<div class="card mb-5" style="box-shadow: 0 0 6px 0 #0003;">
							    	<div class="p-4" id="headingFour">
							      		<h4 class="mb-0 float-left">
							    			How is your shipment configured?
							    		</h4>
						        		<a id="shipment_edit_btn" type="button" t-att-class="'btn btn-outline-info float-right %s' % ('disabled' if not shipping_type else '')" data-toggle="collapse" data-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
						          			Edit
						        		</a>
							    	</div>
							    	<div id="collapseFour" t-att-class="'collapse %s'  % ('show' if shipping_type and not quantity_update else '')" aria-labelledby="headingFour" data-parent="#accordion">
							      		<div class="card-body">
							      			<div class="o_shipment_form w-100">
							      				<div t-att-class="'%s' % ('' if shipping_type == 'parcel' and inventory_type_parcel == 'single' else 'd-none')" id="shipmentTableDiv">
							      					<input t-if="wro_single_sku_per_box_ids" type="hidden" id="single_sku_box_line_ids" name="single_sku_box_line_ids" t-att-value="wro_single_sku_per_box_ids.ids"/>
										            <table class="table mt-5" id="shipmentSingleSkuBoxTable">
										            	<h3>Single SKU Per Box</h3>
													  	<thead>
														    <tr>
																<th scope="col">Item Information</th>
																<th scope="col">Shipment Quantity</th>
																<th scope="col">Quantity Per Box</th>
																<th scope="col"># Of Boxes</th>
																<th scope="col">Package value (₦)</th>
																<th scope="col">Type of Boxes</th>
																<th scope="col">Consolidation Type</th>
																<!-- <th scope="col">Total Quantity</th> -->
														    </tr>
													  	</thead>
													  	<tbody>
													  		<t t-foreach="wro_single_sku_per_box_ids" t-as="line_id">
													  			<tr t-att-id="'single_sku_%s' % (line_id.id)">
									                                <td><t t-esc="line_id.product_id.name"/></td>
									                                <td><t t-esc="line_id.product_qty" t-options='{"widget": "float", "precision": 2}'/></td>
									                                <td>
									                                	<input type="number"  min="1" t-att-max="line_id.product_qty" class="form-control" t-att-id="'single_sku_qty_per_box_%s' % (line_id.id)" t-att-name="'single_sku_qty_per_box_%s' % (line_id.id)" t-att-value="line_id.qty_per_box or line_id.product_qty" onchange="onchange_quantity_per_box(this)" t-att-data-custom_key="line_id.id"/>
									                                </td>
									                                <td>
									                                	<input type="number" step="0.01" min="1" t-att-max="line_id.product_qty" class="form-control" t-att-id="'no_of_box_qty_%s' % (line_id.id)" t-att-name="'no_of_box_qty_%s' % (line_id.id)" t-att-value="line_id.no_of_boxes or 1" onchange="onchange_quantity_per_box(this)" t-att-data-custom_key="line_id.id"/>
									                                </td>
									                                <td><t t-esc="line_id.package_value" t-options='{"widget": "float", "precision": 2}'/></td>
									                                <td>
									                                	<select t-att-id="'box_size_%s' %(line_id.id)" class="form-control" required="required" nt-att-name="'box_size_%s' % (line_id.id)">
							                                                <!-- <option value="" selected="selected" disabled="True">Please select an option...</option> -->
							                                                <t t-foreach="box_size_ids" t-as="box_size_id">
								                                                <option t-att-value="box_size_id.id" t-att-selected="'selected' if line_id and line_id.box_size.id == box_size_id.id else None"><span t-field='box_size_id.name'/></option>
								                                            </t>
							                                                
							                                            </select>
									                                </td>
									                                 <td>
									                                	<select t-att-id="'consolidated_type_%s' %(line_id.id)" class="form-control" required="required" nt-att-name="'consolidated_type_%s' % (line_id.id)">
							                                                <!-- <option value="" selected="selected" disabled="True">Please select an option...</option> -->
							                                               <option value="consolidated" t-att-selected="'selected' if line_id and line_id.consolidated_type == 'consolidated' else None">Consolidated</option>
							                                                <option value="non_consolidated" t-att-selected="'selected' if line_id and line_id.consolidated_type == 'non_consolidated' else None">Non-Consolidated</option>
							                                               
							                                                
							                                            </select>
									                                </td>
									                                <!-- <td t-att-id="'single_sku_box_tqty_%s' % (line_id.id)"></td> -->
									                        	</tr>
															</t>
													    </tbody>
													</table>
												</div>
												<div t-att-class="'%s' % ('' if shipping_type == 'pallet' and inventory_type_pallet == 'single' else 'd-none')" id="shipmentTableDiv">
													<input t-if="wro_single_sku_per_pallet_ids" type="hidden" id="single_sku_pallet_line_ids" name="single_sku_pallet_line_ids" t-att-value="wro_single_sku_per_pallet_ids.ids"/>
										            <table class="table mt-5" id="shipmentSingleSkuPalletTable">
										            	<h3>Single SKU Per Pallet</h3>
													  	<thead>
														    <tr>
																<th scope="col">Item Information</th>
																<th scope="col">Shipment Ouantity</th>
																<th scope="col">Quantity Per Pallet</th>
																<th scope="col"># Of Pallets</th>
																<th scope="col">Package value (₦)</th>
																<th scope="col">Consolated Type</th>
														    </tr>
													  	</thead>
													  	<tbody>
													  		<t t-foreach="wro_single_sku_per_pallet_ids" t-as="line_id">
													  			<tr t-att-id="'single_sku_%s' % (line_id.id)">
									                                <td><t t-esc="line_id.product_id.name"/></td>
									                                <td><t t-esc="line_id.product_qty" t-options='{"widget": "float", "precision": 2}'/></td>
									                                <td>
									                                	<input type="number"  min="1" t-att-max="line_id.product_qty" class="form-control" t-att-id="'single_sku_qty_per_pallet_%s' % (line_id.id)" t-att-name="'single_sku_qty_per_pallet_%s' % (line_id.id)" t-att-value="line_id.qty_per_pallet or 1" onchange="onchange_quantity_per_pallet(this)" t-att-data-custom_key="line_id.id"/>
									                                </td>
									                                <td>
									                                	<input type="number" step="0.01" min="1" t-att-max="line_id.product_qty" class="form-control" t-att-id="'no_of_pallet_qty_%s' % (line_id.id)" t-att-name="'no_of_pallet_qty_%s' % (line_id.id)" t-att-value="line_id.no_of_pallets or 1" onchange="onchange_quantity_per_pallet(this)" t-att-data-custom_key="line_id.id"/>
									                                </td>
									                                <td><t t-esc="line_id.package_value" t-options='{"widget": "float", "precision": 2}'/></td>
									                                 <td>
									                                	<select t-att-id="'consolidated_type_%s' %(line_id.id)" class="form-control" required="required" nt-att-name="'consolidated_type_%s' % (line_id.id)">
							                                                <!-- <option value="" selected="selected" disabled="True">Please select an option...</option> -->
							                                               <option value="consolidated" t-att-selected="'selected' if line_id and line_id.consolidated_type == 'consolidated' else None">Consolidated</option>
							                                                <option value="non_consolidated" t-att-selected="'selected' if line_id and line_id.consolidated_type == 'non_consolidated' else None">Non-Consolidated</option>
							                                               
							                                                
							                                            </select>
									                                </td>
									                                <!-- <td t-att-id="'single_sku_pallet_tqty_%s' % (line_id.id)"></td> -->
									                        	</tr>
															</t>
													    </tbody>
													</table>
												</div>
												<div class="some-class d-none" t-if="(shipping_type == 'pallet' and inventory_type_pallet == 'single') or (shipping_type == 'parcel' and inventory_type_parcel == 'single')">
												    <input type="radio" class="radio" name="consolited_type" value="consolidated" id="consolited" t-att-checked="True if wro_id and (wro_id.consolidated_type == 'consolidated' or wro_id.consolidated_type == False) else False"/>
											        <label for="consolited">Send As Consolidated</label>
											        <input type="radio" class="radio" name="consolited_type" value="non_consolidated" id="non_consolited" t-att-checked="True if wro_id and (wro_id.consolidated_type == 'non_consolidated') else False"/>
