<odoo>
    <data>
        <!-- explicit list view definition -->

        <record model="ir.ui.view" id="storage_box_list_view">
            <field name="name">storage.type.list.view</field>
            <field name="model">storage.type</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                   <!--  <field name="product_id"/>
                    <field name="price"/> -->
                    
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="storage_box_form_view">
            <field name="name">storage.box.form.view</field>
            <field name="model">storage.type</field>
            <field name="arch" type="xml">
            <form>
                
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" class="oe_inline" />
                            </h1>
                        </div>

                        <group>
                        <group>
                            <field name="storage_type"/>
                            <field name="product_id" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="price"/>
                            
                        </group>
                    </group>
                    
                   <!--  <notebook >
                        <page string="Storage Type Lines">
                            <field name="storage_type_line">
                                <tree editable="bottom">
                                    <field name="billing_type_id"/>
                                    <field name="product_id"/>
                                    <field name="price"/>
                                </tree>
                            </field>
                        </page>
                    </notebook> -->
                        
                </sheet>
                
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="storage_box_action_window">
        <field name="name">Storage Type</field>
        <field name="res_model">storage.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Storage Type
            </p>
        </field>
    </record>
    
    <!-- Top menu item -->
    <menuitem id="menu_storage_box" name="Storage Type" action="storage_box_action_window"
    parent="ag_the_hub.menu_thehub_config" sequence="6"/>


  </data>
</odoo>
