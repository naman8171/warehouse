<odoo>
    <data>
        <!-- explicit list view definition -->

        <record model="ir.ui.view" id="warehouse_receive_order_list_view">
            <field name="name">warehouse.receive.order.list.view</field>
            <field name="model">warehouse.receive.order</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="warehouse_id"/>
                    <field name="third_party_ref"/>
                    <field name="shipping_type"/>
                    <field name="pickup_method"/>
                    <field name="arrival_date"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="warehouse_receive_order_form_view">
            <field name="name">warehouse.receive.order.form.view</field>
            <field name="model">warehouse.receive.order</field>
            <field name="arch" type="xml">
            <form>
                <header>
                    <field name="show_received_done_btn" invisible="1"/>
                    <field name="dispute_raised" invisible="1"/>
                    <field name="show_label_button" invisible="1"/>
                    <field name="show_picker_btn" invisible="1"/>
                    <button name="action_wro_picked" type="object" string="WRO Picked" class="oe_highlight" attrs="{'invisible': ['|', ('pickup_method', '!=', 'the_hub'),('status', '!=', 'request_submitted')]}"/>
                    <button name="action_wro_arrived" type="object" string="WRO Arrived" class="oe_highlight" attrs="{'invisible': [('status', '!=', False)]}"/>
                    <button name="action_wro_received" type="object" string="WRO Received" class="oe_highlight" attrs="{'invisible': ['|',('show_received_done_btn', '=', False),('status', 'in', ['received','stored'])]}"/>
                    <button name="action_wro_stored" type="object" string="WRO Stored" class="oe_highlight" attrs="{'invisible': ['|',('show_picker_btn', '=', False),('status', '!=', 'received')]}"/>
                    <button name="action_print_grn_report" type="object" string="Print GRN" class="oe_highlight" attrs="{'invisible': [('status', 'not in', ['received', 'stored'])]}"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_raise_dispute" type="object" class="oe_stat_button" icon="fa-legal" style="background: red;color: white;" attrs="{'invisible': ['|',('show_received_done_btn', '=', False),('dispute_raised','=',True)]}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Raise Dispute</span>
                                
                            </div>
                        </button>
                        <button name="action_view_sale_order" type="object" class="oe_stat_button" icon="fa-dollar" attrs="{'invisible': [('sale_order_count', '=', 0)]}">
                            <field name="sale_order_count" widget="statinfo" string="Sale Order"/>
                        </button>
                        <!-- <button name="action_raise_dispute_open" type="object" class="oe_stat_button" icon="fa-legal" style="background: red;color: white;" attrs="{'invisible': ['|',('show_received_done_btn', '=', False),('dispute_raised','=',False)]}">
                                <field name="ticket_count" widget="statinfo" string="Raise Dispute"/>
                                
                            
                        </button> -->
                        <button name="action_open_picking" type="object" class="oe_stat_button" icon="fa-truck"  attrs="{'invisible': [('status', 'not in', ['stored'])]}">
                                <field name="picking_count" widget="statinfo" string="Transfer"/>
                                
                            
                        </button>
                        
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" class="oe_inline" readonly="1"/>
                            </h1>
                        </div>
                    <group>
                        <group>
                            <field name="merchand_id" required="1" domain="[('contact_type','=','Merchant')]"  attrs="{'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="active" invisible="1"/>
                            <field name="warehouse_id" attrs="{'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="stored_date" invisible="1"/>
                            <field name="last_billing_date" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="shipping_type" attrs="{'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="inventory_type_parcel" attrs="{'invisible': [('shipping_type', '!=', 'parcel')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="inventory_type_pallet" attrs="{'invisible': [('shipping_type', '!=', 'pallet')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="pickup_method" attrs="{'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="consolidated_type" invisible="1"/>
                            <field name="contact_name" attrs="{'invisible': [('pickup_method', '!=', 'the_hub')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="picking_address" attrs="{'invisible': [('pickup_method', '!=', 'the_hub')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                        </group>
                        <group>
                            <field name="phone" attrs="{'invisible': [('pickup_method', '!=', 'the_hub')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="email" attrs="{'invisible': [('pickup_method', '!=', 'the_hub')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="courier_company_name" attrs="{'invisible': [('pickup_method', '!=', 'order_courier_company')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="tracking_number" attrs="{'invisible': [('pickup_method', '!=', 'order_courier_company')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="arrival_date" string="Expected Pickup Date" attrs="{'invisible': [('pickup_method', '!=', 'the_hub')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="arrival_date" string="Expected Arrival Date" attrs="{'invisible': [('pickup_method', '!=', 'order_courier_company')], 'readonly': [('status', 'in', ['received', 'stored'])]}"/>
                            <field name="third_party_ref"/>
                            <field name="dispute_description" attrs="{'readonly': [('dispute_raised', '=', True)]}"/>
                            <field name="wro_type" required="1"/>
                            <field name="wo_id" attrs="{'invisible': [('wro_type', '=', 'New')], 'required': [('wro_type', '=', 'Returned')]}" domain="[('merchand_id', '=', merchand_id), ('status', '=', 'Returned')]"/>
                            <!-- <field name="location_id" attrs="{'required': [('show_received_done_btn', '=', True)], 'readonly': [('show_received_done_btn', '=', False)]}"/> -->
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="wro_line_ids">
                                <tree editable="bottom" >
                                    <field name="merchand_id" invisible="1"/>
                                    <field name="product_id" required="1"/>
                                    <field name="product_sku" readonly="1"/>
                                    <field name="platform" readonly="1"/>
                                    <field name="product_qty" required="1"/>
                                    <field name="package_value" required="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Single SKU Per Box" attrs="{'invisible': [('shipping_type', '!=', 'parcel')]}">
                            <button name="action_line_import" type="object" string="Bulk Import" class="oe_highlight" attrs="{'invisible': [('status', '!=', False)]}"/>
                            <field name="wro_single_sku_per_box_ids">
                                <tree   editable="bottom" delete="0">
                                    <field name="merchand_id" invisible="1"/>
                                    <field name="product_id" domain="['|', ('partner_id','=',merchand_id), ('partner_id.child_ids','in',merchand_id)]" required="1"/>
                                    <field name="product_qty" />
                                    <field name="qty_per_box" />
                                    <field name="no_of_boxes" />
                                    <!-- <field name="subtotal_qty" readonly="1"/> -->
                                    <field name="package_value" />
                                    <field name="consolidated_type"/>
                                    <field name="box_size" readonly="1"/>
                                    <button name="edit_quantity" string="Edit" type="object" attrs="{'column_invisible': ['|', ('parent.dispute_raised', '=', False), ('parent.show_received_done_btn', '=', False)]}" />
                                    

                                    <button name="validate_lines" string="Validate" type="object"  />
                                    <button name="print_labels" string="Print Labels" type="object"  attrs="{'column_invisible': ['|', ('parent.status', 'not in', ['received','stored']), ('parent.show_label_button', '=', False)]}"/>
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="wro_id"/>
                                            <field name="product_qty"/>
                                            <field name="no_of_boxes"/>
                                            <field name="package_value"/>
                                            <field name="consolidated_type"/>
                                        </group>
                                        <group>
                                            <field name="product_id"/>
                                            <field name="qty_per_box"/>
                                        </group>
                                        <field name="wro_single_sku_per_box_line_ids">
                                            <tree>
                                                <field name="package_number"/>
                                                <field name="location_id" attrs="{'column_invisible': [('parent.consolidated_type', '=', 'consolidated')]}"/>
                                                
                                                <field name="send_as"/>
                                            </tree>
                                            <form>
                                                <group>
                                                    <group>
                                                        <field name="package_number"/>
                                                        <field name="send_as"/>
                                                    </group>
                                                </group>
                                                <notebook>
                                                    <page string="Product Packages">
                                                        <field name="wro_single_sku_per_box_product_line_ids">
                                                            <tree>
                                                                <field name="package_number"/>
                                                                <field name="send_as"/>
                                                                <field name="location_id"/>
                                                            </tree>
                                                        </field>
                                                    </page>
                                                </notebook>
                                            </form>
                                        </field>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Single SKU Per Pallet" attrs="{'invisible': [('shipping_type', '!=', 'pallet')]}">
                             <button name="action_line_import" type="object" string="Bulk Import" class="oe_highlight" attrs="{'invisible': [('status', '!=', False)]}"/>
                            <field name="wro_single_sku_per_pallet_ids">
                                <tree delete="false" editable="bottom" >
                                    <field name="merchand_id" invisible="1"/>
                                    <field name="product_id" domain="['|', ('partner_id','=',merchand_id), ('partner_id.child_ids','in',merchand_id)]" required="1"/>
                                    
                                    <field name="product_qty" />
                                    <field name="qty_per_pallet" />
                                    <field name="no_of_pallets" />
                                    <field name="consolidated_type" required="1"/>
                                    <field name="subtotal_qty" invisible="1"/>
                                    <field name="package_value" />
                                    <button name="edit_quantity" string="Edit" type="object" attrs="{'column_invisible': ['|', ('parent.dispute_raised', '=', False), ('parent.show_received_done_btn', '=', False)]}" />

                                    <button name="validate_lines" string="Validate" type="object"  />
                                    <button name="print_labels" string="Print Labels" type="object"  attrs="{'column_invisible': ['|', ('parent.status', 'not in', ['received','stored']), ('parent.show_label_button', '=', False)]}"/>
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="wro_id"/>
                                            <field name="product_qty"/>
                                            <field name="no_of_pallets"/>
                                            <field name="package_value"/>
                                        </group>
                                        <group>
                                            <field name="product_id"/>
                                            <field name="qty_per_pallet"/>
                                        </group>
                                        <field name="wro_single_sku_per_pallet_line_ids">
                                            <tree>
                                                <field name="package_number"/>
                                                <field name="location_id"/>
                                                <field name="send_as"/>
                                            </tree>
                                        </field>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="warehouse_receive_order_action_window">
        <field name="name">Warehouse Receive Order</field>
        <field name="res_model">warehouse.receive.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Warehouse Receive Order
            </p>
        </field>
    </record>

    <menuitem id="menu_wro_root"
            name="OMS"
            web_icon="ag_the_hub,static/description/icon.png"
            active="True"
            sequence="20"/>

    
    <!-- Top menu item -->
    <menuitem id="menu_warehouse_receive_order" name="WRO" action="warehouse_receive_order_action_window"
    parent="menu_wro_root" sequence="1"/>


    <record model="ir.ui.view" id="warehouse_single_sku_pallet_line_form_view">
            <field name="name">single.sku.per.pallet.line.form.view</field>
            <field name="model">single.sku.per.pallet.line</field>
            <field name="arch" type="xml">
                 <form>
                    <header>
                     <button name="action_go_back" type="object" string="Go Back" class="oe_highlight" />
                </header>
                                                <group>
                                                    <group>
                                                        <field name="package_number" readonly="1"/>
                                                        <field name="send_as" readonly="1"/>
                                                        <field name="show_picker_btn" invisible="1"/>
                                            <field name="show_received_done_btn" invisible="1"/>
                                            <field name="location_name" attrs="{'invisible': [('show_picker_btn', '=', False)]}"/>
                                             <button name="action_update_location_label" type="object" string="Update Location Label" class="oe_highlight"  attrs="{'invisible': ['|',('show_picker_btn', '=', False),('location_name', '=', False)]}"/>
                                                    </group>
                                                </group>
                                                <notebook>
                                                    <page string="Product Packages">
                                                        <button name="action_select_all_lines" type="object" string="Select All Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}" style="margin: 6px;"/>
                                                        <button name="action_validate_lines" type="object" string="Validate Selected Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}"/>
                                                        <!-- <field name="wro_single_sku_per_box_product_line_ids"> -->
                                                        <field name="wro_single_sku_per_pallet_product_line_ids">
                                                            <tree decoration-success="is_validated == True" decoration-danger="is_validated == False" editable="bottom" create="0" delete="0">
                                                                <field name="is_selected"/>
                                                                <field name="package_number" readonly="1"/>
                                                                <field name="merchand_id" invisible="1"/>
                                                                <field name="show_received_done_btn" invisible="1"/>
                                                                <field name="location_id" attrs="{'readonly': [('is_validated','=', True)]}"/>
                                                                <field name="is_validated" invisible="1"/>
                                                                <field name="location_label" attrs="{'column_invisible': [('parent.show_picker_btn', '=', False)],'readonly': [('is_validated','=', True)]}"/>
                                                                <field name="scan_package_number" attrs="{'column_invisible': [('parent.show_picker_btn', '=', False)],'readonly': [('is_validated','=', True)]}"/>
                                                                <field name="send_as_pallet" readonly="1"/>
                                                                <button name="validate" string="Validate" type="object"  attrs="{'invisible': [('is_validated', '=', True)]}"/>
                                                            </tree>
                                                        </field>
                                                    </page>
                                                </notebook>
                                            </form>
            </field>
        </record>


    <record model="ir.ui.view" id="warehouse_single_sku_box_line_form_view">
            <field name="name">single.sku.per.box.line.form.view</field>
            <field name="model">single.sku.per.box.line</field>
            <field name="arch" type="xml">
                 <form>
                    <header>
                    <button name="action_go_back" type="object" string="Go Back" class="oe_highlight" />
                    
                    
                </header>
                                                <group>
                                                    <group>
                                                        <field name="package_number" readonly="1"/>
                                                        <field name="send_as" readonly="1"/>
                                                        <field name="show_picker_btn" invisible="1"/>
                                            <field name="show_received_done_btn" invisible="1"/>
                                            <field name="location_name" attrs="{'invisible': [('show_picker_btn', '=', False)]}"/>
                                             <button name="action_update_location_label" type="object" string="Update Location Label" class="oe_highlight"  attrs="{'invisible': ['|',('show_picker_btn', '=', False),('location_name', '=', False)]}"/>
                                                    </group>
                                                </group>
                                                <notebook>
                                                    <page string="Product Packages">
                                                        <field name="is_validated" invisible="1"/>
                                                        <button name="action_select_all_lines" type="object" string="Select All Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}" style="margin: 6px;"/>
                                                        <button name="action_validate_lines" type="object" string="Validate Selected Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}"/>
                                                        <field name="wro_single_sku_per_box_product_line_ids">
                                                            <tree decoration-success="is_validated == True" decoration-danger="is_validated == False" editable="bottom" create="0" delete="0">
                                                                <field name="is_selected"/>
                                                                <field name="package_number" readonly="1"/>
                                                                <field name="merchand_id" invisible="1"/>
                                                                 <field name="show_picker_btn" invisible="1"/>
                                            <field name="show_received_done_btn" invisible="1"/>
                                                                <field name="location_id" attrs="{'readonly': [('is_validated','=', True)]}"/>
                                                                <field name="is_validated" invisible="1"/>

                                                                <field name="location_label" attrs="{'column_invisible': [('parent.show_picker_btn', '=', False)],'readonly': [('is_validated','=', True)]}"/>
                                                                <field name="scan_package_number" attrs="{'column_invisible': [('parent.show_picker_btn', '=', False)],'readonly': [('is_validated','=', True)]}"/>
                                                                <field name="packing_type_id" readonly="1" attrs="{'readonly': [('is_validated','=', True)]}"/>

                                                                <field name="send_as" readonly="1"/>
                                                                <button name="add_packaging_cost" string="Add Packaging" type="object" attrs="{'readonly': [('is_validated','=', True)]}" />
                                                                <button name="validate" string="Validate" type="object"  attrs="{'invisible': [('is_validated', '=', True)]}"/>
                                                            </tree>
                                                        </field>
                                                    </page>
                                                </notebook>
                                            </form>
            </field>
        </record>

        

    <record model="ir.ui.view" id="warehouse_single_sku_box_form_view">
            <field name="name">wro.single.sku.per.box.form.view</field>
            <field name="model">wro.single.sku.per.box</field>
            <field name="arch" type="xml">
        
            <form>
                
                                    <group>
                                        <group>
                                            <field name="wro_id" readonly="1"/>
                                            <field name="product_qty" readonly="1"/>
                                            <field name="no_of_boxes" readonly="1"/>
                                            <field name="package_value" readonly="1"/>
                                            <field name="consolidated_type" readonly="1"/>
                                            <field name="show_picker_btn" invisible="1"/>
                                            <field name="show_received_done_btn" invisible="1"/>
                                        </group>
                                        <group>
                                            <field name="product_id" readonly="1"/>
                                            <field name="qty_per_box" readonly="1"/>
                                            <field name="location_name" attrs="{'invisible': ['|',('show_picker_btn', '=', False),('consolidated_type', '=', 'non_consolidated')]}"/>
                                            <button name="cascade_lines" type="object" string="Update Location" class="oe_highlight"  attrs="{'invisible': ['|','|',('show_picker_btn', '=', False),('location_name', '=', False),('consolidated_type', '=', 'non_consolidated')]}" style="margin: 6px;"/>
                                            <field name="is_default_location" readonly="1"/>
                                            <field name="defaultlocation_id" readonly="1"/>
                                        </group>
                                         </group>
                                        <notebook>
                                            <page string="Lines">
                                                <button name="action_report_discrepancy" type="object" string="Report Discrepancy" class="oe_highlight" style="margin: 6px;"/>
                                        <button name="select_all_line" type="object" string="Select all Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}" style="margin: 6px;"/>
                                                
                                        <button name="action_validate_lines" type="object" string="Validate Selected Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}" style="margin: 6px;"/>
                                        <field name="wro_single_sku_per_box_line_ids">
                                            
                                            <tree editable="bottom" decoration-success="is_validated == True" decoration-danger="is_validated == False" create="0" delete="0">
                                                <field name="is_selected" attrs="{'readonly': [('is_validated', '=', True)]}"/>
                                                <field name="package_number" readonly="1"/>
                                                <field name="is_validated" invisible="1"/>
                                                <field name="merchand_id" invisible="1"/>
                                                <field name="show_received_done_btn" invisible="1"/>
                                                <field name="location_id"  attrs="{'readonly': [('is_validated', '=', True)],'column_invisible': [('parent.consolidated_type', '=', 'non_consolidated')]}"/>
                                                <field name="location_label" attrs="{'column_invisible': ['|',('parent.show_picker_btn', '=', False),('parent.consolidated_type', '=', 'non_consolidated')],'readonly': [('is_validated','=', True)]}"/>
                                                <field name="scan_package_number" attrs="{'column_invisible': ['|',('parent.show_picker_btn', '=', False),('parent.consolidated_type', '=', 'non_consolidated')],'readonly': [('is_validated','=', True)]}"/>
                                                <field name="is_package_required" invisible="1"/>
                                                                <field name="packing_type_id" readonly="1" attrs="{'readonly': [('is_validated', '=', True)],'column_invisible': [('parent.consolidated_type', '=', 'non_consolidated')]}"/>
                                                <field name="send_as" readonly="1"/>
                                                <!-- <button name="create_picker_activity" string="Picker Activity" type="object"  attrs="{'column_invisible': [('parent.show_received_done_btn', '=', False)]}" /> -->
                                                <button name="add_packaging_cost" string="Add Packaging" type="object" attrs="{'readonly': [('is_validated', '=', True)],'column_invisible': [('parent.consolidated_type', '=', 'non_consolidated')]}" />
                                                <button name="validate" string="Validate" type="object"  attrs="{'invisible': [('is_validated', '=', True)]}" />
                                                 <button class="o_optional_button" name="action_open_view" type="object" icon="fa-list"  attrs="{'invisible': [('send_as', '=', 'consolidated')]}"/>
                                
                                            </tree>
                                            <form>
                                                <group>
                                                    <group>
                                                        <field name="package_number"/>
                                                        <field name="send_as"/>
                                                    </group>
                                                </group>
                                                <notebook>
                                                    <page string="Product Packages">
                                                        <field name="wro_single_sku_per_box_product_line_ids">
                                                            <tree decoration-success="is_validated == True" decoration-danger="is_validated == False" editable="bottom">
                                                                <field name="package_number"/>
                                                                <field name="is_validated"/>
                                                                <field name="send_as"/>
                                                                <field name="merchand_id" invisible="1"/>
                                                                <field name="location_id"/>
                                                                <field name="location_label"/>
                                                                <field name="scan_package_number"/>
                                                            </tree>
                                                        </field>
                                                    </page>
                                                </notebook>
                                            </form>
                                        </field>
                                    </page>
                                    </notebook>
                                   
                                </form>
                            </field>
                        </record>



    <record model="ir.ui.view" id="warehouse_single_sku_pallet_form_view">
            <field name="name">wro.single.sku.per.pallet.form.view</field>
            <field name="model">wro.single.sku.per.pallet</field>
            <field name="arch" type="xml">
                <form>
                    
                
                                    <group>
                                        <group>
                                            <field name="wro_id" readonly="1"/>
                                            <field name="product_qty" readonly="1"/>
                                            <field name="no_of_pallets" readonly="1"/>
                                            <field name="package_value" readonly="1"/>
                                            <field name="show_picker_btn" invisible="1"/>
                                            <field name="consolidated_type" readonly="1"/>
                                            <field name="show_received_done_btn" invisible="1"/>
                                        </group>
                                        <group>
                                            <field name="product_id" readonly="1"/>
                                            <field name="qty_per_pallet" readonly="1"/><field name="location_name" attrs="{'invisible': ['|',('show_picker_btn', '=', False),('consolidated_type', '=', 'non_consolidated')]}"/>
                                            <button name="cascade_lines" type="object" string="Update Location" class="oe_highlight"  attrs="{'invisible': ['|','|',('show_picker_btn', '=', False),('location_name', '=', False),('consolidated_type', '=', 'non_consolidated')]}" style="margin: 6px;"/>
                                            <field name="is_default_location" readonly="1"/>
                                            <field name="defaultlocation_id" readonly="1"/>
                                        </group>
                                         </group>
                                        <notebook>
                                            <page string="Lines">
                                        <button name="select_all_line" type="object" string="Select all Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}" style="margin: 6px;"/>
                                                
                                        <button name="action_validate_lines" type="object" string="Validate Selected Line" class="oe_highlight"  attrs="{'invisible': [('show_picker_btn', '=', False)]}" style="margin: 6px;"/>
                                        <field name="wro_single_sku_per_pallet_line_ids">
                                            <tree decoration-success="is_validated == True" decoration-danger="is_validated == False" editable="bottom" create="0" delete="0">
                                                <field name="is_selected"/>
                                                <field name="package_number" readonly="1"/>
                                                <field name="merchand_id" invisible="1"/>
                                                <field name="show_received_done_btn" invisible="1"/>
                                                 <field name="location_id"  attrs="{'readonly': [('is_validated', '=', True)],'column_invisible': [('parent.consolidated_type', '=', 'non_consolidated')]}"/>
                                                <field name="location_label" attrs="{'column_invisible': ['|',('parent.show_picker_btn', '=', False),('parent.consolidated_type', '=', 'non_consolidated')]}"/>
                                                <field name="scan_package_number" attrs="{'column_invisible': ['|',('parent.show_picker_btn', '=', False),('parent.consolidated_type', '=', 'non_consolidated')]}"/>
                                                <field name="send_as" readonly="1"/>
                                                <field name="is_package_required" invisible="1"/>
                                                                <field name="packing_type_id" invisible="1"/>
                                                <!-- <button name="add_packaging_cost" string="Add Packaging" type="object" attrs="{'invisible': [('show_received_done_btn', '=', False)]}" /> -->
                                               
                                                <field name="is_validated" invisible="1"/>
                                                <button name="validate" string="Validate" type="object"  attrs="{'invisible': [('is_validated', '=', True)]}" />
                                                 <button class="o_optional_button" name="action_open_view" type="object" icon="fa-list" attrs="{'invisible': [('send_as', '=', 'consolidated')]}" />
                                            </tree>
                                        </field>
                                    </page>
                                </notebook>
                                </form>
        
            </field>
        </record>



  </data>
