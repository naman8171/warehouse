    <template id="portal_my_3PL_companies" name="My 3PL Companies">
        <t t-call="portal.frontend_layout">
		<div class="col-12 d-flex flex-row-reverse">
                <button type="button" data-toggle="modal" data-target="#add3plcompany" class="btn btn-success" style="font-size:20px;font-weight:bold;">Add 3PL Company</button>
            </div>
            <div class="modal fade" id="add3plcompany" tabindex="-1" role="dialog" aria-labelledby="add3plcompany" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content">
                        <div class="modal-body">
                            <h1 class="text-center d-block mt-2">Add 3PL Company</h1>
                            <div class="text-center d-block mt-2">
                                You can add extra information later.
                            </div>
                            <form id="add3plcompany" action="/add/3PLCompany/manually" method="post"
                                  enctype="form-data">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="form-group">
                                    <label for="product_name">Name</label>
                                    <input type="text" class="form-control" id="name" name="name" placeholder="Enter Name" required="1"/>
                                </div>
                                <div class="form-group">
                                    <label for="sku_number">Email</label>
                                    <input type="text" class="form-control" id="email" name="email" placeholder="Enter Email" required="1"/>
                                    
                                </div>
                                <div class="form-group">
                                    <label for="product_name">Phone Number</label>
                                    <input type="text" class="form-control" id="phone" name="phone" placeholder="Enter Phone Number" required="1"/>
                                </div>
                                <button type="submit" class="btn btn-success float-right" style="font-size:20px;font-weight:bold;">Add 3PL Company</button>
                            </form>

                            <!-- Close Button -->
                            <div class="text-center d-block mt-2">
                                <a class="font-size:14px" href="#" data-dismiss="modal" aria-label="Close">
                                    Close
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

                <nav aria-label="breadcrumb flex justify-between" style="background-color:#e9ecef;margin-left: 0%;">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item "><a class="bold text-danger" href="/my">THL</a></li>
                      <li class="breadcrumb-item active" aria-current="page" style="background: transparent;">3PL Company</li>
                    </ol>
                  </nav>
