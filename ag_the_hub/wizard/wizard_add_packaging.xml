<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_add_packaging_form" model="ir.ui.view">
            <field name="name">add.packaging.form</field>
            <field name="model">add.packaging</field>
            <field name="arch" type="xml">
                <form>
                    <group>
	                    <group >
                            <field name="packing_categ" required="1"/>
                            <field name="packing_type_id" required="1"/>
                            <field name="address"/>
                            <field name="weight"/>
                            <field name="wo_id"/>
                            <field name="wo_line_products_ids" widget="many2many_tags" invisible="1"/>
                            <field name="product_ids" widget="many2many_tags" required="1" domain="[('id', 'in', wo_line_products_ids)]" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="selected_line_ids" widget="many2many_tags" options="{'no_create': True, 'no_create_edit':True}"/>
                            <!-- <field name="product_qty"/> -->
                        </group>
                        
                    </group>
                    <notebook>
                        <page string="Product Lines">
                            <field name="available_product_lines" required="1" force_save="1">
                                <tree editable="bottom" create="0" edit="0" delete="0">
                                    <!-- <field name="select"/> -->
                                    <field name="product_id"/>
                                    <field name="package_id"/>
                                    <field name="send_as"/>
                                    <field name="wo_line" readonly="1" force_save="1"/>
                                    <!-- <field name=""/> -->
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="add_package_pack" string="Add Package" type="object" class="btn-primary" />
                        
                        
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_add_package" model="ir.actions.act_window">
            <field name="name">Add Package</field>
            <field name="res_model">add.packaging</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_add_packaging_form"/>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
