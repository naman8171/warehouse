<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_wo_line_import_form" model="ir.ui.view">
            <field name="name">wo.line.import.form</field>
            <field name="model">wo.line.import</field>
            <field name="arch" type="xml">
                <form>
                    <group>
	                    <group >
                            <!-- <field name="wro_shipping_type" attrs="{'invisible': [('is_manual', '!=', False)]}"/> -->
                            <field name="product_ids" invisible="1"/>
                            <field name="send_as" />
                            <field name="product_id" required="1" domain="[('id', 'in', product_ids)]" force_save="1" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="available_qty" force_save="1"/>
                            <field name="send_qty"/>
                            <field name="package_id" attrs="{'invisible': [('is_manual', '=', False)],'required': [('is_manual', '!=', False)]}" widget="many2many_tags"/>
                            <field name="is_manual" invisible="1"/>
                            
                            <!-- <field name="product_qty"/> -->
                        </group>
                        <group >
                            <field name="delivery_address"/>
                            <field name="weight"/>
                        </group>
                    </group>
                    <footer>
                        <button name="import_line" string="Add" type="object" class="btn-primary" />
                        
                        
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_wo_line_import" model="ir.actions.act_window">
            <field name="name">Add Line</field>
            <field name="res_model">wo.line.import</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_wo_line_import_form"/>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
