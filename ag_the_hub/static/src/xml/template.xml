              <div class="form-field product">
                <select t-if="product_ids" class="multi_select product_id" id="select_multi_product" t-attf-name="product_#{wo_id}"  multiple="multiple" style="margin:8px auto;min-width: 176px;min-height: 40px;">
                                                        <t t-foreach="product_ids" t-as="product" t-key='product.id'>
                                                            <option t-att-value="product.id">
                                                                <t t-esc='product.name'/>
                                                            </option>
                                                        </t>
                                                    </select>
                
              </div>
          </td>
          <td colspan="1">
              <div class="form-field quantity">
                  <input required="required" type="number"  class="form-control o_required_modifier text-left" value="1"  t-attf-name="quantity_#{wo_id}" min="1"/>
              </div>
          </td>
